# Environment Variables
# All variables ore optional, as they come configured with some sane defaults

# HTTP Server Configuration
HOST='localhost' # Application host (Defaults to "localhost")
PORT=3000 # Application port (Defaults to 3000)

# CORS Configuration
CORS_ORIGINS='https://localhost:3000,http://localhost:3000' # CORS origins (Defaults to "https://localhost:3000,http://localhost:3000")

