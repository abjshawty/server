{
  "name": "server-template",
  "version": "0.3.6",
  "private": "false",
  "type": "module",
  "module": "src/index.ts",
  "description": "Functional template for a backend server, using Fastify and Prisma",
  "author": "abjshawty",
  "homepage": "https://github.com/abjshawty/server#readme",
  "contributors": [
    "Timmy Kouadio-Bhegnin <kouadiobhegnino@gmail.com> (https://abjshawty.dev)"
  ],
  "engineStrict": true,
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.0.0",
    "yarn": ">=1.22.19"
  },
  "keywords": [
    "server",
    "template",
    "fastify",
    "prisma"
  ],
  "main": "build/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/abjshawty/server.git"
  },
  "bugs": {
    "url": "https://github.com/abjshawty/server/issues",
    "email": "kouadiobhegnino@gmail.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "bench": "tsx scripts/bench.ts",
    "test": "jest --watchAll",
    "format": "prettier --write ./src",
    "db:gen": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev --name dev",
    "db:push": "prisma db push",
    "db:reset": "yarn && prisma migrate reset --force && prisma migrate dev --name dev",
    "create": "prisma generate && ts-node src/helpers/generator.ts && prettier --write ./src",
    "db:auth": "npx @better-auth/cli generate --config ./src/utils",
    "db:init": "yarn && yarn db:reset && yarn db:auth && yarn db:migrate",
    "update": "npx npm-check-updates -u && yarn"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.0",
    "@fastify/cors": ">=11.1.0",
    "@fastify/helmet": ">=13.0.2",
    "@fastify/jwt": ">=10.0.0",
    "@fastify/multipart": ">=9.3.0",
    "@fastify/swagger": ">=9.x",
    "@fastify/swagger-ui": ">=5.x",
    "@prisma/adapter-mariadb": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "7.0.0",
    "axios": "^1.13.2",
    "better-auth": "^1.3.34",
    "death": ">=1.1.0",
    "dotenv": ">=17.2.3",
    "exceljs": ">=4.4.0",
    "fastify": ">=5.6.2",
    "form-data": "^4.0.5",
    "json2csv": ">=6.0.0-alpha.2",
    "kafkajs": ">=2.2.4",
    "pdfkit-table": "^0.1.99",
    "prettier": "^3.6.2",
    "prisma": "^7.0.0",
    "redis": "^5.10.0",
    "resend": "^6.6.0"
  },
  "devDependencies": {
    "@types/death": ">=1.1.5",
    "@types/jest": ">=30.0.0",
    "@types/node": ">=22.10.1",
    "autocannon": "^8.0.0",
    "jest": ">=30.2.0",
    "nodemon": ">=3.1.11",
    "pino-pretty": ">=13.1.2",
    "prettier-plugin-space-before-function-paren": ">=0.0.9",
    "ts-jest": "^29.4.5",
    "ts-node": ">=10.9.2",
    "tsx": "^4.20.6",
    "typescript": ">=5.9.3"
  },
  "config": {},
  "license": "WTFPL",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": true,
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "coverageDirectory": "coverage",
    "coverageProvider": "v8",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}