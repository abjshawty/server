{
  "name": "bun-server",
  "module": "src/index.ts",
  "version": "0.0.0",
  "type": "module",
  "description": "Functional template for a backend server, using Bun & Convex",
  "private": false,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "dev:debug": "bun --watch --inspect src/index.ts",
    "dev:watch": "bun --hot src/index.ts"
  },
  "engineStrict": true,
  "engines": {
    "bun": ">=1.3.6"
  },
  "contributors": [
    "Timmy Kouadio-Bhegnin <kouadiobhegnino@gmail.com> (https://abjshawty.dev)"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
