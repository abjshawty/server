{
    "name": "server-template",
    "version": "0.3.2",
    "private": "false",
    "description": "Functional template for a backend server, using Fastify and Prisma",
    "keywords": [
        "server",
        "template",
        "fastify",
        "prisma"
    ],
    "main": "build/index.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/abjshawty/server.git"
    },
    "bugs": {
        "url": "https://github.com/abjshawty/server/issues",
        "email": "kouadiobhegnino@gmail.com"
    },
    "contributors": [
        "Timmy Kouadio-Bhegnin <kouadiobhegnino@gmail.com> (https://abjshawty.dev)"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "nodemon src/index.ts",
        "start": "node build/index.js",
        "test": "jest --watchAll",
        "format": "prettier --write ./src",
        "db:gen": "prisma generate",
        "db:migrate": "prisma migrate dev --name dev",
        "db:reset": "npm i && prisma migrate reset --force && prisma migrate dev --name dev",
        "create": "prisma generate && ts-node src/helpers/generator.ts && prettier --write ./src"
    },
    "dependencies": {
        "@fastify/cors": ">=11.1.0",
        "@fastify/helmet": ">=13.0.2",
        "@fastify/jwt": ">=10.0.0",
        "@fastify/multipart": ">=9.3.0",
        "@fastify/swagger": ">=9.x",
        "@fastify/swagger-ui": ">=5.x",
        "@prisma/client": "6.18.0",
        "death": ">=1.1.0",
        "dotenv": ">=17.2.3",
        "exceljs": ">=4.4.0",
        "fastify": ">=5.6.1",
        "json2csv": ">=6.0.0-alpha.2",
        "kafkajs": ">=2.2.4",
        "pdfkit-table": "^0.1.99",
        "prettier": "^3.6.2",
        "prisma": "^6.18.0",
        "redis": "^5.9.0"
    },
    "devDependencies": {
        "@types/death": ">=1.1.5",
        "@types/jest": ">=30.0.0",
        "@types/node": ">=24.10.0",
        "jest": ">=30.2.0",
        "nodemon": ">=3.1.10",
        "pino-pretty": ">=13.1.2",
        "prettier-plugin-space-before-function-paren": ">=0.0.9",
        "ts-node": ">=10.9.2",
        "typescript": ">=5.9.3"
    },
    "author": "abjshawty",
    "config": {},
    "license": "WTFPL",
    "jest": {
        "verbose": true,
        "testEnvironment": "node",
        "setupFilesAfterEnv": [
            "./src/test/setup.ts"
        ],
        "coverageDirectory": "coverage",
        "coverageProvider": "v8"
    }
}